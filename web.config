<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <system.webServer>
        <security>
            <requestFiltering>
                <!-- 50 MB in bytes = 52428800 -->
                <requestLimits maxAllowedContentLength="52428800" />
            </requestFiltering>
        </security>
    </system.webServer>
    <system.web>
        <!-- 50 MB in kilobytes = 51200, executionTimeout in seconds -->
        <httpRuntime maxRequestLength="51200" executionTimeout="300" />
    </system.web>
</configuration>
